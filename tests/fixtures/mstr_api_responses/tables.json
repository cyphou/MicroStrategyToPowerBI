  {
    "id": "GG12367511D3E4D81000E787EC6DE8A4",
    "name": "VW_MONTHLY_SUMMARY",
    "physicalTable": {
      "tableName": "VW_MONTHLY_SUMMARY",
      "namespace": "dbo",
      "tablePrefix": ""
    },
    "logicalSize": 0,
    "isFreeformSql": true,
    "sqlStatement": "SELECT c.CUSTOMER_ID, c.CUSTOMER_NAME, p.PRODUCT_ID, p.PRODUCT_NAME, d.MONTH_ID, d.YEAR_ID, SUM(s.REVENUE) AS MONTHLY_REVENUE, SUM(s.QUANTITY) AS MONTHLY_QUANTITY FROM FACT_SALES s JOIN LU_CUSTOMER c ON s.CUSTOMER_ID = c.CUSTOMER_ID JOIN LU_PRODUCT p ON s.PRODUCT_ID = p.PRODUCT_ID JOIN LU_DATE d ON s.DATE_ID = d.DATE_ID GROUP BY c.CUSTOMER_ID, c.CUSTOMER_NAME, p.PRODUCT_ID, p.PRODUCT_NAME, d.MONTH_ID, d.YEAR_ID",
    "columns": [
      {"id": "col_050", "name": "CUSTOMER_ID", "dataType": "integer", "length": 4},
      {"id": "col_051", "name": "CUSTOMER_NAME", "dataType": "nVarChar", "length": 255},
      {"id": "col_052", "name": "PRODUCT_ID", "dataType": "integer", "length": 4},
      {"id": "col_053", "name": "PRODUCT_NAME", "dataType": "nVarChar", "length": 255},
      {"id": "col_054", "name": "MONTH_ID", "dataType": "integer", "length": 4},
      {"id": "col_055", "name": "YEAR_ID", "dataType": "integer", "length": 4},
      {"id": "col_056", "name": "MONTHLY_REVENUE", "dataType": "real", "length": 8},
      {"id": "col_057", "name": "MONTHLY_QUANTITY", "dataType": "integer", "length": 4}
    ],
