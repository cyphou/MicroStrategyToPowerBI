relationship rel_LU_CUSTOMER_FACT_SALES
	fromColumn: LU_CUSTOMER.CUSTOMER_ID
	toColumn: FACT_SALES.CUSTOMER_ID
	crossFilteringBehavior: oneDirection

relationship rel_LU_PRODUCT_FACT_SALES
	fromColumn: LU_PRODUCT.PRODUCT_ID
	toColumn: FACT_SALES.PRODUCT_ID
	crossFilteringBehavior: oneDirection

relationship rel_LU_DATE_FACT_SALES
	fromColumn: LU_DATE.DATE_ID
	toColumn: FACT_SALES.DATE_ID
	crossFilteringBehavior: oneDirection

relationship rel_LU_PRODUCT_FACT_INVENTORY
	fromColumn: LU_PRODUCT.PRODUCT_ID
	toColumn: FACT_INVENTORY.PRODUCT_ID
	crossFilteringBehavior: oneDirection

relationship rel_LU_DATE_FACT_INVENTORY
	fromColumn: LU_DATE.DATE_ID
	toColumn: FACT_INVENTORY.DATE_ID
	crossFilteringBehavior: oneDirection
