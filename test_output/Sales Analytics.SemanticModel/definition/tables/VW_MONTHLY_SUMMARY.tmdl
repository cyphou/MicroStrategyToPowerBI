	partition VW_MONTHLY_SUMMARY = m
		mode: import
		expression:= ```
			let
			    Source = Odbc.DataSource("DSN=sql-prod-01.company.com"),
			    Query = Value.NativeQuery(Source, "SELECT c.CUSTOMER_ID, c.CUSTOMER_NAME, p.PRODUCT_ID, p.PRODUCT_NAME, d.MONTH_ID, d.YEAR_ID, SUM(s.REVENUE) AS MONTHLY_REVENUE, SUM(s.QUANTITY) AS MONTHLY_QUANTITY FROM FACT_SALES s JOIN LU_CUSTOMER c ON s.CUSTOMER_ID = c.CUSTOMER_ID JOIN LU_PRODUCT p ON s.PRODUCT_ID = p.PRODUCT_ID JOIN LU_DATE d ON s.DATE_ID = d.DATE_ID GROUP BY c.CUSTOMER_ID, c.CUSTOMER_NAME, p.PRODUCT_ID, p.PRODUCT_NAME, d.MONTH_ID, d.YEAR_ID")
			in
			    Query
			```
