model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["LU_CUSTOMER","LU_PRODUCT","LU_DATE","FACT_SALES","FACT_INVENTORY"]

ref table LU_CUSTOMER
ref table LU_PRODUCT
ref table LU_DATE
ref table FACT_SALES
ref table FACT_INVENTORY

ref relationship rel_LU_CUSTOMER_FACT_SALES
ref relationship rel_LU_PRODUCT_FACT_SALES
ref relationship rel_LU_DATE_FACT_SALES
ref relationship rel_LU_PRODUCT_FACT_INVENTORY
ref relationship rel_LU_DATE_FACT_INVENTORY

ref role 'Region Sales Filter'
ref role 'Product Category Filter'

